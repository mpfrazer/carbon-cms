# Carbon CMS — production Docker env.
# Copy to .env (cp .env.docker.example .env) and fill in real values
# before running `docker compose up`.
#
# For local dev compose (docker-compose.dev.yml), no .env is needed — that
# file hardcodes safe dev-only placeholders.
# For the `npm run dev` workflow, see .env.example instead.

# ── Required ──────────────────────────────────────────────────────────────

# Postgres password — used by both the db service and the api's DATABASE_URL.
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=

# Session secret for Auth.js. Generate with: openssl rand -base64 32
# Shared by api / admin / frontend so they can verify each other's session
# cookies. DO NOT commit a real value.
AUTH_SECRET=

# Domain Carbon serves under. Caddy provisions Let's Encrypt certs for
# both ${CARBON_DOMAIN} (frontend) and admin.${CARBON_DOMAIN} (admin).
# Must resolve publicly via DNS pointing at this host.
CARBON_DOMAIN=

# Email Caddy uses for ACME registration / cert-expiry notices.
CADDY_EMAIL=

# Public frontend URL — used for canonical links, OpenGraph, JSON-LD.
# Typically https://${CARBON_DOMAIN}.
CARBON_PUBLIC_URL=

# ── Service ports (defaults usually fine) ────────────────────────────────

API_PORT=3001
ADMIN_PORT=3002
FRONTEND_PORT=3003

# ── Optional ──────────────────────────────────────────────────────────────

# Comma-separated origin list allowed to call the API across origins. Add
# any external frontend / mobile-app origins. Same-origin (frontend +
# admin under CARBON_DOMAIN) is allowed automatically by Caddy.
# CARBON_ALLOWED_ORIGINS=

# Storage driver for uploaded media.
# - "local": stores under /srv/media inside the api container; persisted
#            via the docker volume defined in docker-compose.yml.
# - "s3":    stores in an S3-compatible bucket (requires AWS_* below).
STORAGE_DRIVER=local

# S3 config (only needed when STORAGE_DRIVER=s3)
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

# Pin a specific Carbon version. Defaults to :latest (which floats to the
# most recent release once the release pipeline is set up).
# CARBON_VERSION=v0.1.0

# AI authoring tools (admin-side excerpt / SEO / title suggesters)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
