FROM node:20-alpine AS base

FROM base AS builder
WORKDIR /app
COPY package*.json ./
COPY packages/api/package.json ./packages/api/
COPY packages/admin/package.json ./packages/admin/
COPY packages/frontend/package.json ./packages/frontend/
RUN npm ci
COPY packages/api ./packages/api
ENV NEXT_TELEMETRY_DISABLED=1
# Dummy value so the module-level DATABASE_URL guard passes at build time.
# The real value is supplied at container runtime via the environment.
ENV DATABASE_URL=postgresql://build:build@localhost/placeholder
RUN npm run build -w packages/api

FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs

COPY --from=builder --chown=nextjs:nodejs /app/packages/api/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/packages/api/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/packages/api/src/themes ./src/themes

USER nextjs
ENV PORT=3001
ENV HOSTNAME=0.0.0.0
EXPOSE 3001

CMD ["node", "server.js"]
