# Carbon CMS — local development env.
# Copy to .env (cp .env.example .env) and fill in real values.
#
# For Docker installs see .env.docker.example instead. This file is for
# the `npm run dev` workflow against a hosted or local Postgres.

# ── Required ──────────────────────────────────────────────────────────────

# Postgres connection string. Anything postgres-compatible works.
# Examples:
#   Neon:       postgresql://user:pass@host.neon.tech/dbname?sslmode=require
#   Supabase:   postgresql://postgres:pass@db.<ref>.supabase.co:5432/postgres
#   Local:      postgresql://carbon:carbon@localhost:5432/carbon
DATABASE_URL=

# Session secret for Auth.js. Generate with: openssl rand -base64 32
# DO NOT reuse across environments. DO NOT commit a real value.
AUTH_SECRET=

# ── Service URLs (defaults work for the standard `npm run dev` ports) ────

# Each Next.js process has its own NEXTAUTH_URL pointing at its own port.
# `npm run dev` runs api / admin / frontend on 3001 / 3002 / 3003.
NEXTAUTH_URL=http://localhost:3001

# Where the admin and frontend processes find the API. For dev they're all
# on localhost; for split deployments these become the public API origin.
CARBON_API_URL=http://localhost:3001

# Public frontend URL — used for canonical links, OpenGraph, JSON-LD.
CARBON_PUBLIC_URL=http://localhost:3003

# Comma-separated origin list allowed to call the API across origins. Leave
# blank to allow only same-origin requests (sensible default for dev).
# CARBON_ALLOWED_ORIGINS=

# ── Optional: media storage ──────────────────────────────────────────────

# "local" writes uploads to disk (MEDIA_DIR); "s3" writes to S3 (set AWS_*).
STORAGE_DRIVER=local
MEDIA_DIR=./uploads

# S3 config (only needed when STORAGE_DRIVER=s3)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

# ── Optional: AI authoring tools ─────────────────────────────────────────

# Set either to enable the AI excerpt / SEO / title suggesters in the admin.
# Leave both empty to no-op the AI features.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
